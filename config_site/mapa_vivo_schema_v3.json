{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mapa Vivo Schema v3.1",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "version": { "type": "string" },
    "updatedAt": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "body": { "type": "string" },
          "type": { "enum": ["hub", "biblioteca", "feed", "qbank", "tool", "module", "topic", "theme", "file"] },
          "status": { "enum": ["ativo", "planejado", "sugerido", "oculto", "rejeitado"] },
          "url": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "visible": { "type": "boolean" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "relation"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "relation": { "type": "string" },
          "strength": { "enum": ["direct", "suggested"] },
          "status": { "enum": ["ativo", "sugerido", "oculto", "rejeitado"] },
          "visible": { "type": "boolean" },
          "reason": { "type": "string" },
          "createdBy": { "type": "string" }
        }
      }
    }
  }
}
